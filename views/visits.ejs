<head>
  <title>Επισκέψεις</title>
  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css?family=Ubuntu" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.3.7/dist/css/bootstrap.min.css"
    integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous" />
</head>

<body onload="themistoklis()">
  <script src="myglobals.js" type="text/javascript"></script>
  <script src="dist/include-html.min.js"></script>
  <div data-include="/menu.html"></div>
  <div data-include="/sidebar.html"></div>
  <section id="history"></section>

</body>
<script>
  const history = document.getElementById("history");

  function themistoklis() {
    history.innerHTML = "";
    fetch("test2", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({}),
    })
      .then((res) => res.json())
      .then((data) => {
        console.log(data.length)
        if (data.length == 0) {
          history.innerHTML += `<div class="box" style="border: 5px solid #4c27b0; border-radius: 10px"><div class="panel-body">
                    <p>Δεν βρέθηκαν επισκέψεις</p>
                  </div></div>`;
        } else {
          data.forEach((item, index) => {
            let localDate = new Date(item.timestamp);
            if (index >= 0) {
              history.innerHTML += 
                `<div class="box" style="border: 5px solid #4c27b0; border-radius: 10px"> 
                  <div class="panel-body">
                    <p>Δήλωσες επίσκεψη στην τοποθεσία ${item.name} στις ${localDate.toLocaleString()} με ${item.people_estimate} επισκέπτες</p>
                  </div>
                </div>`;
            }
          });
        }
      });
  }
</script>

